# ── API BASE URL ─────────────────────────────────────────────────
# ✅ Production — Railway backend (ACTIVE)
# VITE_API_BASE_URL=https://dooarsgreenbackand-production.up.railway.app/api

# Local development (frontend & backend on same PC)
# VITE_API_BASE_URL=http://localhost:8080/api

# Same-WiFi device (e.g. phone/tablet testing)
VITE_API_BASE_URL=http://10.5.0.2:8080/api


# ── APP CONFIG ───────────────────────────────────────────────────
VITE_APP_NAME=Dooars Green
VITE_APP_VERSION=1.0.0
